{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Book2befit",
  "colors": {
    "primary": "#16A34A",
    "light": "#22C55E",
    "dark": "#15803D"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Getting Started",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "index",
              "quickstart"
            ]
          }
        ]
      },
      {
        "tab": "Core Features",
        "groups": [
          {
            "group": "Scheduling",
            "pages": [
              "core-features/sessions",
              "core-features/bookings"
            ]
          },
          {
            "group": "Studio Management",
            "pages": [
              "core-features/clients",
              "core-features/payments",
              "core-features/team"
            ]
          },
          {
            "group": "Client Experience",
            "pages": [
              "core-features/public-portal"
            ]
          }
        ]
      },
      {
        "tab": "Reference",
        "groups": [
          {
            "group": "Plans & Data",
            "pages": [
              "reference/tiers",
              "reference/database-schema"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Homepage",
          "href": "https://book2befit.com",
          "icon": "house"
        },
        {
          "anchor": "Support",
          "href": "mailto:support@book2befit.com",
          "icon": "envelope"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:support@book2befit.com"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Open App",
      "href": "https://app.book2befit.com"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "claude",
      "cursor"
    ]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/book2befit",
      "instagram": "https://instagram.com/book2befit"
    }
  }
}
